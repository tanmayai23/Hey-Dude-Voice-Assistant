# ========================================
# ENVIRONMENT VARIABLES TEMPLATE
# ========================================
# Copy this file to .env and add your actual API keys
# NEVER commit the .env file to GitHub!

# Google Gemini AI API Key
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Skip face authentication (for testing)
# Set to 'true' to skip face authentication
SKIP_FACE_AUTH=false

# ===== Wake word (offline, "Hey Boss") =====
# Free AccessKey from https://console.picovoice.ai/
# Without this, hotword falls back to slow speech_recognition polling.
PICOVOICE_ACCESS_KEY=

# Path to a .ppn file trained on console.picovoice.ai for "Hey Boss".
# Leave empty to use a built-in keyword (defaults to 'jarvis').
WAKE_WORD_PPN_PATH=

# Built-in keyword used when no custom .ppn is set. Options include:
# alexa, americano, blueberry, bumblebee, computer, grapefruit, grasshopper,
# hey google, hey siri, jarvis, ok google, picovoice, porcupine, terminator
WAKE_WORD_BUILTIN=jarvis

# Turn the always-listening hotword loop on
ENABLE_HOTWORD=false

# ===== Proactive system monitor =====
# Watches RAM/CPU and offers to clean caches when they spike. Cheap (~60s poll).
ENABLE_SYSTEM_MONITOR=true

# ===== Voice (TTS) =====
# 'kokoro' uses cloud Kokoro-82M via DeepInfra (warm, natural voice, ~$0.06/hr
# of audio). Falls back to pyttsx3 automatically if the API key is missing or
# the network is down. Set to 'pyttsx3' to force the local SAPI5 voice.
TTS_PROVIDER=kokoro

# DeepInfra API key — get one at https://deepinfra.com/dash/api_keys
DEEPINFRA_API_KEY=

# Kokoro voice. Options include: af_heart (warm female, default),
# af_bella, af_nicole, am_adam, am_michael, bf_emma, bm_george, etc.
# Full list: https://huggingface.co/hexgrad/Kokoro-82M/blob/main/VOICES.md
KOKORO_VOICE=af_heart

# ===== Speech-to-text (ASR) =====
# 'groq' uses Whisper-large-v3-turbo via Groq's free tier (~8 hours of
# audio per day, no credit card needed). Falls back to Google's free
# endpoint (recognize_google) if the key is missing or the network fails.
# Set to 'google' to force the old behavior.
ASR_PROVIDER=groq

# Get a free Groq key at https://console.groq.com/keys
GROQ_API_KEY=

# Whisper model on Groq. 'whisper-large-v3-turbo' is fastest and free-tier
# friendly. 'whisper-large-v3' is slightly more accurate but costs more quota.
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Language hint for Whisper. 'en' biases toward English (works well for
# Hinglish since Whisper handles Roman-script Hindi naturally). Leave
# empty ('') for full auto-detect.
ASR_LANGUAGE=en
